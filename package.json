{
  "name": "clinica-odontologica",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=18.18.0"
  },
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:turbo": "next dev --turbo -H 127.0.0.1 -p 3001",
    "build": "next build",
    "start": "next start",
    "clean": "node -e \"const fs=require('fs'); const paths=['.next','.next-dev','.turbo','node_modules/.cache/dental-next']; for (const p of paths) { try { fs.rmSync(p,{recursive:true,force:true}); } catch(e) {} }\"",
    "lint": "eslint ."
  },
  "dependencies": {
    "@supabase/ssr": "^0.6.1",
    "@supabase/supabase-js": "^2.106.2",
    "lucide-react": "^1.17.0",
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.1.0",
    "@types/node": "20.17.6",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.0.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.6.0"
  }
}
